    "deploy:lambda": "bash scripts/deploy-lambda.sh"
  },
  "dependencies": {
    "convex": "^1.17.0",
    "jspdf": "^4.2.1",
    "marked": "^18.0.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
