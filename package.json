{
  "name": "toward-love",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "convex dev",
    "dev:all": "npm-run-all --parallel dev dev:backend",
    "build": "tsc -b && vite build",
